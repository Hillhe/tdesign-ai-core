{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vite/client"],
    "paths": {
      "@tdesign/ai-chat-engine": ["../chat-engine/index.ts"],
      "@tdesign/ai-chat-engine/*": ["../chat-engine/*"],
      "@tdesign/ai-shared": ["../shared/index.ts"],
      "@tdesign/ai-shared/*": ["../shared/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts"]
}
